USE tutor_platform;

-- 1) Create database users
CREATE USER IF NOT EXISTS 'database_admin'@'localhost' IDENTIFIED BY 'Admin123!';
CREATE USER IF NOT EXISTS 'database_moderator'@'localhost' IDENTIFIED BY 'Moder123!';
CREATE USER IF NOT EXISTS 'database_teacher'@'localhost' IDENTIFIED BY 'Teacher123!';
CREATE USER IF NOT EXISTS 'database_student'@'localhost' IDENTIFIED BY 'Student123!';
CREATE USER IF NOT EXISTS 'database_support'@'localhost' IDENTIFIED BY 'Support123!';

-- 2) Admin: full access
GRANT ALL PRIVILEGES ON tutor_platform.* TO 'database_admin'@'localhost';

-- 3) Moderator: read everything + moderate teacher profiles / documents / reviews
GRANT SELECT ON tutor_platform.* TO 'database_moderator'@'localhost';
GRANT UPDATE ON tutor_platform.teacher_profile TO 'database_moderator'@'localhost';
GRANT UPDATE ON tutor_platform.documents TO 'database_moderator'@'localhost';
GRANT UPDATE, DELETE ON tutor_platform.reviews TO 'database_moderator'@'localhost';

-- 4) Teacher: read + update own profile and lessons
GRANT SELECT ON tutor_platform.* TO 'database_teacher'@'localhost';
GRANT UPDATE ON tutor_platform.teacher_profile TO 'database_teacher'@'localhost';
GRANT UPDATE ON tutor_platform.lessons TO 'database_teacher'@'localhost';

-- 5) Student: can create lessons, payments, reviews
GRANT SELECT ON tutor_platform.* TO 'database_student'@'localhost';
GRANT INSERT, UPDATE, DELETE ON tutor_platform.lessons TO 'database_student'@'localhost';
GRANT INSERT ON tutor_platform.payments TO 'database_student'@'localhost';
GRANT INSERT, UPDATE, DELETE ON tutor_platform.reviews TO 'database_student'@'localhost';

-- 6) Support: read everything + can update lesson status to help users
GRANT SELECT ON tutor_platform.* TO 'database_support'@'localhost';
GRANT UPDATE ON tutor_platform.lessons TO 'database_support'@'localhost';

FLUSH PRIVILEGES;
